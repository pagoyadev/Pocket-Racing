# Normalize EOL for all files that Git considers text files.
* text=auto eol=lf

# Binary assets: never EOL-normalize or diff as text (avoids corruption + bloat).
*.glb   binary
*.gltf  binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.webp  binary
*.ogg   binary
*.wav   binary
*.mp3   binary
*.ttf   binary
*.otf   binary
