config_version=5

[application]

config/name="Star Racer Client"
config/version="0.1.0"
run/main_scene="uid://byhujfase7yp8"
config/features=PackedStringArray("4.6", "Forward Plus")
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/show_image=false

[debug_draw_3d]

